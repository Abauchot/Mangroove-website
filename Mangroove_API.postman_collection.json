{
	"info": {
		"name": "Mangroove API",
		"description": "Collection Postman pour l'API Mangroove avec authentification JWT",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{jwt_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "jam_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "🔐 Authentification",
			"item": [
				{
					"name": "Login - Obtenir JWT Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extraire automatiquement le token JWT et le stocker",
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    if (responseJson.token) {",
									"        pm.collectionVariables.set('jwt_token', responseJson.token);",
									"        console.log('✅ Token JWT sauvegardé automatiquement');",
									"    }",
									"} else {",
									"    console.log('❌ Échec de l\\'authentification');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@mangroove.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"login"
							]
						},
						"description": "Authentification pour obtenir un token JWT.\n\n**Utilisateur de test :**\n- Email: user@mangroove.com\n- Password: password123\n\n⚡ Le token sera automatiquement sauvegardé pour les autres requêtes."
					},
					"response": []
				},
				{
					"name": "Register - Créer un compte",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"nouveau@example.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"register"
							]
						},
						"description": "Créer un nouveau compte utilisateur."
					},
					"response": []
				}
			],
			"description": "Endpoints d'authentification pour obtenir et gérer les tokens JWT."
		},
		{
			"name": "👥 Users API",
			"item": [
				{
					"name": "Get All Users",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users"
							]
						},
						"description": "Récupérer la liste de tous les utilisateurs.\n\n🔒 **Authentification requise**"
					},
					"response": []
				},
				{
					"name": "Get User by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/users/{{user_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users",
								"{{user_id}}"
							]
						},
						"description": "Récupérer un utilisateur spécifique par son ID UUID.\n\n🔒 **Authentification requise**\n\n💡 Utilisez une variable {{user_id}} ou remplacez par un UUID valide."
					},
					"response": []
				},
				{
					"name": "Create User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extraire automatiquement l'ID de l'utilisateur créé et le stocker",
									"if (pm.response.code === 201) {",
									"    const responseJson = pm.response.json();",
									"    if (responseJson.id) {",
									"        pm.collectionVariables.set('user_id', responseJson.id);",
									"        console.log('✅ ID de l\\'utilisateur sauvegardé automatiquement: ' + responseJson.id);",
									"    }",
									"} else {",
									"    console.log('❌ Échec de la création de l\\'utilisateur');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/ld+json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"nouvel.user@example.com\",\n  \"password\": \"motdepasse123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users"
							]
						},
						"description": "Créer un nouvel utilisateur via l'API Platform.\n\n🔒 **Authentification requise**\n\n⚡ L'ID de l'utilisateur sera automatiquement sauvegardé pour les autres requêtes."
					},
					"response": []
				},
				{
					"name": "Update User",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/merge-patch+json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"email.modifie@example.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/users/{{user_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users",
								"{{user_id}}"
							]
						},
						"description": "Mettre à jour un utilisateur existant.\n\n🔒 **Authentification requise**\n\n💡 Utilisez une variable {{user_id}} ou remplacez par un UUID valide."
					},
					"response": []
				},
				{
					"name": "Delete User",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/users/{{user_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users",
								"{{user_id}}"
							]
						},
						"description": "Supprimer un utilisateur.\n\n🔒 **Authentification requise**\n\n💡 Utilisez une variable {{user_id}} ou remplacez par un UUID valide.\n\n⚠️ **Attention :** Cette action est irréversible."
					},
					"response": []
				}
			],
			"description": "Endpoints pour gérer les utilisateurs via API Platform."
		},
		{
			"name": "🎯 Jams API",
			"item": [
				{
					"name": "Get All Jams",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/jams",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"jams"
							]
						},
						"description": "Récupérer la liste de toutes les jams.\n\n🔒 **Authentification requise**"
					},
					"response": []
				},
				{
					"name": "Get Jams by Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/jams?status=published",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"jams"
							],
							"query": [
								{
									"key": "status",
									"value": "published",
									"description": "Filtrer par statut (draft, published, active, completed, cancelled)"
								}
							]
						},
						"description": "Filtrer les jams par statut.\n\n🔒 **Authentification requise**\n\n📋 **Statuts disponibles :**\n- draft: Brouillon\n- published: Publiée\n- active: En cours\n- completed: Terminée\n- cancelled: Annulée"
					},
					"response": []
				},
				{
					"name": "Get Jam by Slug",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/jams?slug=nouvelle-game-jam-2025",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"jams"
							],
							"query": [
								{
									"key": "slug",
									"value": "nouvelle-game-jam-2025",
									"description": "Rechercher par slug (identifiant URL-friendly)"
								}
							]
						},
						"description": "Rechercher une jam par son slug.\n\n🔒 **Authentification requise**\n\n💡 Le slug est l'identifiant URL-friendly de la jam."
					},
					"response": []
				},
				{
					"name": "Get Jam by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/jams/{{jam_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"jams",
								"{{jam_id}}"
							]
						},
						"description": "Récupérer une jam spécifique par son ID UUID.\n\n🔒 **Authentification requise**\n\n💡 Utilisez une variable {{jam_id}} ou remplacez par un UUID valide."
					},
					"response": []
				},
				{
					"name": "Create Jam",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extraire automatiquement l'ID de la jam créée et le stocker",
									"if (pm.response.code === 201) {",
									"    const responseJson = pm.response.json();",
									"    if (responseJson.id) {",
									"        pm.collectionVariables.set('jam_id', responseJson.id);",
									"        console.log('✅ ID de la jam sauvegardé automatiquement: ' + responseJson.id);",
									"    }",
									"} else {",
									"    console.log('❌ Échec de la création de la jam');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/ld+json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Nouvelle Game Jam 2025\",\n  \"slug\": \"nouvelle-game-jam-2025\",\n  \"startsAt\": \"2025-12-01T09:00:00+00:00\",\n  \"endsAt\": \"2025-12-03T23:59:59+00:00\",\n  \"votingEndAt\": \"2025-12-10T23:59:59+00:00\",\n  \"themeSubmissionEndAt\": \"2025-11-25T23:59:59+00:00\",\n  \"themeVotingEndAt\": \"2025-11-30T23:59:59+00:00\",\n  \"theme\": \"Innovation\",\n  \"status\": \"draft\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/jams",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"jams"
							]
						},
						"description": "Créer une nouvelle jam.\n\n🔒 **Authentification requise**\n\n📝 **Champs requis :**\n- title: Titre de la jam\n- slug: Identifiant unique URL-friendly\n- startsAt: Date de début\n- endsAt: Date de fin\n- votingEndAt: Date de fin des votes\n- themeSubmissionEndAt: Date limite soumission de thèmes\n- themeVotingEndAt: Date limite vote des thèmes\n\n📝 **Champs optionnels :**\n- theme: Thème de la jam (peut être défini plus tard)\n- status: Statut (draft par défaut)\n\n📅 **Format des dates :** ISO 8601 (YYYY-MM-DDTHH:MM:SS+00:00)\n\n⚡ L'ID de la jam sera automatiquement sauvegardé pour les autres requêtes."
					},
					"response": []
				},
				{
					"name": "Update Jam",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/merge-patch+json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Game Jam 2025 - Titre Modifié\",\n  \"theme\": \"Nouveau Thème\",\n  \"status\": \"published\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/jams/{{jam_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"jams",
								"{{jam_id}}"
							]
						},
						"description": "Mettre à jour une jam existante.\n\n🔒 **Authentification requise**\n\n💡 Utilisez une variable {{jam_id}} ou remplacez par un UUID valide.\n\n📝 Vous pouvez modifier partiellement les champs de la jam."
					},
					"response": []
				},
				{
					"name": "Delete Jam",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/jams/{{jam_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"jams",
								"{{jam_id}}"
							]
						},
						"description": "Supprimer une jam.\n\n🔒 **Authentification requise**\n\n💡 Utilisez une variable {{jam_id}} ou remplacez par un UUID valide.\n\n⚠️ **Attention :** Cette action est irréversible."
					},
					"response": []
				}
			],
			"description": "Endpoints pour gérer les jams (game jams) via API Platform."
		},
