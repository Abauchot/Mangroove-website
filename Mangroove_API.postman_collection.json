	"item": [
		{
			"name": "🔐 Authentification",
			"item": [
				{
					"name": "Login - Obtenir JWT Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extraire automatiquement le token JWT et le stocker",
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    if (responseJson.token) {",
									"        pm.collectionVariables.set('jwt_token', responseJson.token);",
									"        console.log('✅ Token JWT sauvegardé automatiquement');",
									"    }",
									"} else {",
									"    console.log('❌ Échec de l\\'authentification');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@mangroove.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"login"
							]
						},
						"description": "Authentification pour obtenir un token JWT.\n\n**Utilisateur de test :**\n- Email: user@mangroove.com\n- Password: password123\n\n⚡ Le token sera automatiquement sauvegardé pour les autres requêtes."
					},
					"response": []
				},
				{
					"name": "Register - Créer un compte",
					"request": {
						"auth": {
							"type": "noauth"
						},
